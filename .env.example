# SEC EDGAR User-Agent (required by SEC for programmatic access)
SEC_USER_AGENT_NAME=Your Name
SEC_USER_AGENT_EMAIL=you@email.com

# Database path (relative to project root)
DB_PATH=db/ipo_etf_tracker.db

# --- LLM (OpenAI-compatible) ---
# Any OpenAI-compatible endpoint works (OpenAI, Azure OpenAI, internal proxy, vLLM, etc.).
# Set LLM_API_BASE_URL to your endpoint's /v1 root, or leave blank to use OpenAI's default.
LLM_API_BASE_URL=
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini

# Enrich N-1A filings with LLM-extracted metadata at ingest time (true/false)
LLM_ENRICH_N1A=true

# Max chars of N-1A document text to send to the LLM
LLM_MAX_DOC_CHARS=80000
